# Copy this file to server/.env and fill in real values. Never commit .env.
# Data storage is configured by docker-compose.yml and persists in the named volume.
VIBE_ENVIRONMENT=production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
VIBE_SESSION_SECRET=replace-with-a-random-secret-of-at-least-32-characters
VIBE_SESSION_HTTPS_ONLY=true
VIBE_SESSION_MAX_AGE_SECONDS=43200
# JSON array; replace the first entry with the classroom's actual domain.
# localhost entries allow the on-server health check while the app remains private.
VIBE_ALLOWED_HOSTS=["vibe.example.com","localhost","127.0.0.1"]
# Safe only because docker-compose.yml binds port 8000 to localhost and Caddy is trusted.
VIBE_TRUST_PROXY_HEADERS=true
VIBE_LLM_BASE_URL=https://api.deepseek.com
VIBE_LLM_API_KEY=replace-with-your-key
VIBE_LLM_MODEL=deepseek-chat
VIBE_WORKER_ENABLED=true
